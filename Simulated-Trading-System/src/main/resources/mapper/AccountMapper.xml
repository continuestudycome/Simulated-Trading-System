<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lzq.simulatedtradingsystem.mapper.AccountMapper">
    <select id="findByUserId" resultType="com.lzq.simulatedtradingsystem.domain.Account">
        SELECT
            id,
            user_id,
            balance,
            frozen,
            version
        FROM account
        WHERE id = #{id}
    </select>
</mapper>

